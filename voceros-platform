<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Club de Voceros - Plataforma de Gestión</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --blue-dark:#0d1b2a;
    --blue-main:#0099cc;
    --blue-light:#00c0ff;
    --blue-hover:#0077a3;
    --bg-card:#1a2635;
    --border:#2c3e50;
    --text-primary:#ffffff;
    --text-secondary:#9ab;
    --text-muted:#667;
    --accent-success:#00d4a3;
    --accent-warning:#ffb84d;
    --accent-danger:#ff6b6b;
  }
  
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter',-apple-system,sans-serif;
    background:var(--blue-dark);
    color:var(--text-primary);
    min-height:100vh;
  }
  
  .container{display:flex;min-height:100vh;}
  
  /* SIDEBAR */
  .sidebar{
    width:260px;
    background:linear-gradient(180deg,#0a1420 0%,#0d1b2a 100%);
    border-right:1px solid var(--border);
    padding:24px 0;
    position:fixed;
    left:0;top:0;height:100vh;
    overflow-y:auto;
    z-index:100;
  }
  
  .logo{
    display:flex;
    align-items:center;
    gap:10px;
    padding:0 16px 32px;
    font-weight:700;
    font-size:16px;
    letter-spacing:0.5px;
  }
  .logo svg{width:24px;height:24px;}
  
  .nav-section{
    padding:8px 8px;
    margin:16px 0;
  }
  .nav-label{
    font-size:11px;
    font-weight:600;
    text-transform:uppercase;
    color:var(--text-muted);
    letter-spacing:1px;
    padding:0 16px 8px;
  }
  
  .nav-btn{
    width:calc(100% - 16px);
    margin:0 8px;
    padding:12px 14px;
    background:none;
    border:none;
    border-left:3px solid transparent;
    color:var(--text-secondary);
    font-size:14px;
    font-weight:500;
    cursor:pointer;
    text-align:left;
    transition:all .2s;
    border-radius:0;
  }
  .nav-btn:hover{
    background:rgba(0,99,204,0.1);
    color:var(--text-primary);
  }
  .nav-btn.active{
    background:rgba(0,99,204,0.15);
    color:var(--blue-light);
    border-left-color:var(--blue-main);
  }
  
  .user-box{
    position:absolute;bottom:0;left:0;right:0;
    background:rgba(0,99,204,0.1);
    border-top:1px solid var(--border);
    padding:16px;
    display:flex;
    flex-direction:column;
    gap:8px;
  }
  .user-info{font-size:12px;}
  .user-info strong{display:block;color:var(--text-primary);}
  .user-role{color:var(--blue-light);font-size:11px;font-weight:600;text-transform:uppercase;}
  
  /* MAIN CONTENT */
  .main{
    margin-left:260px;
    flex:1;
    background:var(--blue-dark);
    padding:32px 40px;
    overflow-y:auto;
  }
  
  .panel{display:none;}
  .panel.active{display:block;animation:fadeIn .3s;}
  @keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
  
  /* HEADER */
  .page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:32px;
    border-bottom:1px solid var(--border);
    padding-bottom:20px;
  }
  .page-title{
    font-size:28px;
    font-weight:700;
    margin:0;
  }
  .page-badge{
    font-size:12px;
    background:rgba(0,196,160,0.2);
    color:var(--accent-success);
    padding:6px 12px;
    border-radius:4px;
    font-weight:600;
    text-transform:uppercase;
  }
  
  /* CARDS & GRIDS */
  .grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
    margin-bottom:32px;
  }
  
  .card{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:8px;
    padding:20px;
    transition:all .2s;
  }
  .card:hover{
    border-color:var(--blue-main);
    transform:translateY(-2px);
  }
  
  .card-icon{
    width:40px;
    height:40px;
    background:rgba(0,99,204,0.15);
    border-radius:8px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:20px;
    margin-bottom:12px;
  }
  
  .card-title{
    font-weight:600;
    font-size:16px;
    margin:8px 0;
  }
  .card-text{
    font-size:13px;
    color:var(--text-secondary);
    line-height:1.5;
  }
  .card-meta{
    font-size:12px;
    color:var(--text-muted);
    margin-top:12px;
  }
  
  /* LISTS */
  .list{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:8px;
    margin-bottom:24px;
  }
  .list-header{
    padding:16px 20px;
    border-bottom:1px solid var(--border);
    font-weight:600;
    font-size:14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }
  .list-item{
    padding:16px 20px;
    border-bottom:1px solid var(--border);
    display:flex;
    justify-content:space-between;
    align-items:center;
    transition:background .2s;
  }
  .list-item:hover{background:rgba(0,99,204,0.05);}
  .list-item:last-child{border-bottom:none;}
  
  .list-item-title{
    font-weight:500;
    font-size:14px;
  }
  .list-item-meta{
    font-size:12px;
    color:var(--text-muted);
    margin-top:4px;
  }
  
  .badge{
    display:inline-block;
    padding:4px 8px;
    border-radius:4px;
    font-size:11px;
    font-weight:600;
    text-transform:uppercase;
  }
  .badge-blue{background:rgba(0,99,204,0.2);color:var(--blue-light);}
  .badge-success{background:rgba(0,212,163,0.2);color:var(--accent-success);}
  .badge-warning{background:rgba(255,184,77,0.2);color:var(--accent-warning);}
  .badge-danger{background:rgba(255,107,107,0.2);color:var(--accent-danger);}
  
  /* FORMS */
  .form-group{
    margin-bottom:20px;
    display:flex;
    flex-direction:column;
  }
  .form-group label{
    font-size:13px;
    font-weight:600;
    margin-bottom:6px;
    color:var(--text-primary);
  }
  .form-group input,
  .form-group textarea,
  .form-group select{
    background:var(--bg-card);
    border:1px solid var(--border);
    color:var(--text-primary);
    padding:10px 12px;
    border-radius:6px;
    font-family:inherit;
    font-size:14px;
    transition:border .2s;
  }
  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus{
    outline:none;
    border-color:var(--blue-main);
  }
  .form-group textarea{resize:vertical;min-height:80px;}
  
  /* BUTTONS */
  .btn{
    padding:10px 16px;
    border:none;
    border-radius:6px;
    font-size:14px;
    font-weight:600;
    cursor:pointer;
    transition:all .2s;
    text-transform:uppercase;
    letter-spacing:0.5px;
  }
  .btn-primary{
    background:var(--blue-main);
    color:white;
  }
  .btn-primary:hover{
    background:var(--blue-hover);
  }
  .btn-secondary{
    background:var(--bg-card);
    color:var(--text-secondary);
    border:1px solid var(--border);
  }
  .btn-secondary:hover{
    background:rgba(0,99,204,0.1);
    color:var(--text-primary);
  }
  .btn-small{padding:6px 12px;font-size:12px;}
  
  /* MODALS */
  .modal{
    display:none;
    position:fixed;
    top:0;left:0;right:0;bottom:0;
    background:rgba(0,0,0,0.5);
    z-index:200;
    align-items:center;
    justify-content:center;
  }
  .modal.active{display:flex;}
  .modal-content{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:8px;
    padding:28px;
    width:90%;
    max-width:500px;
    max-height:90vh;
    overflow-y:auto;
  }
  .modal-title{
    font-size:20px;
    font-weight:700;
    margin-bottom:20px;
  }
  .modal-actions{
    display:flex;
    gap:12px;
    margin-top:24px;
    justify-content:flex-end;
  }
  
  /* LOGIN */
  .login-page{
    display:flex;
    align-items:center;
    justify-content:center;
    min-height:100vh;
    padding:20px;
  }
  .login-box{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:12px;
    padding:40px;
    width:100%;
    max-width:400px;
  }
  .login-logo{
    text-align:center;
    margin-bottom:32px;
    font-size:32px;
  }
  .login-title{
    text-align:center;
    font-size:24px;
    font-weight:700;
    margin-bottom:8px;
  }
  .login-subtitle{
    text-align:center;
    color:var(--text-secondary);
    font-size:13px;
    margin-bottom:28px;
  }
  
  /* STATS */
  .stat-row{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:16px;
    margin-bottom:32px;
  }
  .stat{
    background:var(--bg-card);
    border:1px solid var(--border);
    border-radius:8px;
    padding:16px;
    text-align:center;
  }
  .stat-num{
    font-size:28px;
    font-weight:700;
    color:var(--blue-light);
  }
  .stat-label{
    font-size:12px;
    color:var(--text-muted);
    margin-top:6px;
    text-transform:uppercase;
    letter-spacing:0.5px;
  }
  
  /* RESPONSIVE */
  @media(max-width:768px){
    .sidebar{width:100%;height:auto;position:relative;border-right:none;border-bottom:1px solid var(--border);}
    .main{margin-left:0;padding:20px;}
    .page-header{flex-direction:column;align-items:flex-start;gap:12px;}
    .grid{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-page" class="login-page" style="display:flex;">
  <div class="login-box">
    <div class="login-logo">📡</div>
    <div class="login-title">Club de Voceros</div>
    <div class="login-subtitle">Plataforma de Gestión</div>
    
    <div class="form-group">
      <label>Tipo de acceso</label>
      <select id="role-select">
        <option value="">Seleccionar rol...</option>
        <option value="coordinator">Coordinador</option>
        <option value="vocero">Vocero</option>
      </select>
    </div>
    
    <div class="form-group" id="pin-group" style="display:none;">
      <label>PIN del Coordinador</label>
      <input type="password" id="pin-input" placeholder="Ingresa el PIN">
      <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">PIN por defecto: 1234</div>
    </div>
    
    <div class="form-group" id="name-group" style="display:none;">
      <label>Tu nombre</label>
      <input type="text" id="name-input" placeholder="Ej: Juan Carlos">
    </div>
    
    <button class="btn btn-primary" style="width:100%;" onclick="login()">Ingresar</button>
    
    <div style="font-size:12px;color:var(--text-muted);margin-top:20px;text-align:center;">
      <strong>Demo:</strong> Coordinador PIN 1234 o Vocero cualquier nombre
    </div>
  </div>
</div>

<!-- APP -->
<div id="app" style="display:none;width:100%;">
  <div class="container">
    
    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        Voceros
      </div>
      
      <div class="nav-section">
        <div class="nav-label">Principal</div>
        <button class="nav-btn active" onclick="showPanel('dashboard')">🏠 Inicio</button>
      </div>
      
      <div class="nav-section">
        <div class="nav-label">Gestión</div>
        <button class="nav-btn" onclick="showPanel('voceros')">👥 Voceros</button>
        <button class="nav-btn" onclick="showPanel('tareas')">📋 Tareas</button>
        <button class="nav-btn" onclick="showPanel('agenda')">📅 Agenda</button>
      </div>
      
      <div class="nav-section">
        <div class="nav-label">Participación</div>
        <button class="nav-btn" onclick="showPanel('propuestas')">💡 Propuestas</button>
        <button class="nav-btn" onclick="showPanel('comunicacion')">💬 Comunicación</button>
      </div>
      
      <div class="nav-section" id="blog-section" style="display:none;">
        <div class="nav-label">Contenidos</div>
        <button class="nav-btn" onclick="showPanel('blog')">📰 Blog/Noticias</button>
      </div>
      
      <div class="user-box">
        <div class="user-info">
          <strong id="user-name">Usuario</strong>
          <div class="user-role" id="user-role">vocero</div>
        </div>
        <button class="btn btn-secondary btn-small" onclick="logout()" style="width:100%;">Salir</button>
      </div>
    </div>
    
    <!-- MAIN CONTENT -->
    <div class="main">
      
      <!-- DASHBOARD -->
      <div id="panel-dashboard" class="panel active">
        <div class="page-header">
          <h1 class="page-title">Panel Principal</h1>
          <div class="page-badge">● En vivo</div>
        </div>
        
        <div class="stat-row" id="stats-container">
          <div class="stat">
            <div class="stat-num" id="stat-reuniones">3</div>
            <div class="stat-label">Próximas reuniones</div>
          </div>
          <div class="stat">
            <div class="stat-num" id="stat-tareas">5</div>
            <div class="stat-label">Tareas pendientes</div>
          </div>
          <div class="stat">
            <div class="stat-num" id="stat-voceros">12</div>
            <div class="stat-label">Voceros activos</div>
          </div>
          <div class="stat">
            <div class="stat-num" id="stat-propuestas">8</div>
            <div class="stat-label">Propuestas nuevas</div>
          </div>
        </div>
        
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;">
          <div>
            <div class="list-header">⭐ Avisos Importantes</div>
            <div class="list" id="avisos-list">
              <div class="list-item" onclick="editAviso(0)" style="cursor:pointer;">
                <div>
                  <div class="list-item-title">Reunión general del viernes</div>
                  <div class="list-item-meta">Se discutirán nuevas propuestas</div>
                </div>
                <div class="badge badge-warning">URGENTE</div>
              </div>
              <div class="list-item">
                <div>
                  <div class="list-item-title">Plazo para propuestas</div>
                  <div class="list-item-meta">Cierra en 3 días</div>
                </div>
                <div class="badge badge-blue">INFO</div>
              </div>
            </div>
            <button class="btn btn-primary" style="width:100%;margin-top:12px;" id="new-aviso-btn" onclick="toggleAvisoForm()">+ Nuevo aviso</button>
          </div>
          
          <div>
            <div class="list-header">🔄 Actividad Reciente</div>
            <div class="list" id="activity-list">
              <div class="list-item">
                <div>
                  <div class="list-item-title">Vocero nombrado</div>
                  <div class="list-item-meta">Carolina en 2°A • Hace 2h</div>
                </div>
              </div>
              <div class="list-item">
                <div>
                  <div class="list-item-title">Propuesta enviada</div>
                  <div class="list-item-meta">Mejora infraestructura • Hace 5h</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="list-header">📅 Próximas Reuniones</div>
        <div class="list" id="reuniones-list">
          <div class="list-item">
            <div style="flex:1;">
              <div class="list-item-title">Reunión general</div>
              <div class="list-item-meta">Viernes 19 de Julio • 13:00 hs</div>
            </div>
            <div class="badge badge-success">CONFIRMADA</div>
          </div>
        </div>
        <button class="btn btn-primary" style="margin-top:12px;" id="new-reunion-btn" onclick="toggleReunionForm()">+ Agendar reunión</button>
      </div>
      
      <!-- VOCEROS -->
      <div id="panel-voceros" class="panel">
        <div class="page-header">
          <h1 class="page-title">Voceros</h1>
          <button class="btn btn-primary" id="new-vocero-btn" onclick="toggleVoceroForm()" style="display:none;">+ Añadir vocero</button>
        </div>
        
        <div class="list" id="voceros-list">
          <div class="list-header">Lista de voceros por curso</div>
          <div id="voceros-content" style="padding:20px;">Cargando...</div>
        </div>
      </div>
      
      <!-- TAREAS -->
      <div id="panel-tareas" class="panel">
        <div class="page-header">
          <h1 class="page-title">Tareas y Proyectos</h1>
          <button class="btn btn-primary" id="new-tarea-btn" onclick="toggleTareaForm()" style="display:none;">+ Asignar tarea</button>
        </div>
        
        <div class="list" id="tareas-list">
          <div class="list-header">Estado de avance</div>
          <div id="tareas-content" style="padding:20px;">Cargando...</div>
        </div>
      </div>
      
      <!-- AGENDA -->
      <div id="panel-agenda" class="panel">
        <div class="page-header">
          <h1 class="page-title">Agenda y Calendario</h1>
          <button class="btn btn-primary" id="new-evento-btn" onclick="toggleEventoForm()" style="display:none;">+ Nuevo evento</button>
        </div>
        
        <div class="list" id="agenda-list">
          <div class="list-header">Eventos programados</div>
          <div id="agenda-content" style="padding:20px;">Cargando...</div>
        </div>
      </div>
      
      <!-- PROPUESTAS -->
      <div id="panel-propuestas" class="panel">
        <div class="page-header">
          <h1 class="page-title">Propuestas Estudiantiles</h1>
          <button class="btn btn-primary" id="new-propuesta-btn" onclick="togglePropuestaForm()">+ Enviar propuesta</button>
        </div>
        
        <div class="list" id="propuestas-list">
          <div class="list-header">Sugerencias del estudiantado</div>
          <div id="propuestas-content" style="padding:20px;">Cargando...</div>
        </div>
      </div>
      
      <!-- COMUNICACIÓN -->
      <div id="panel-comunicacion" class="panel">
        <div class="page-header">
          <h1 class="page-title">Comunicación Interna</h1>
          <button class="btn btn-primary" id="new-msg-btn" onclick="toggleMsgForm()" style="display:none;">+ Anuncio</button>
        </div>
        
        <div class="list" id="comunicacion-list">
          <div class="list-header">Anuncios y comunicados</div>
          <div id="comunicacion-content" style="padding:20px;">Cargando...</div>
        </div>
      </div>
      
      <!-- BLOG -->
      <div id="panel-blog" class="panel">
        <div class="page-header">
          <h1 class="page-title">Blog de Noticias</h1>
          <button class="btn btn-primary" onclick="toggleBlogForm()">+ Nueva noticia</button>
        </div>
        
        <div id="blog-content" style="padding:20px;">Cargando...</div>
      </div>
      
    </div>
  </div>
</div>

<!-- MODALS -->

<div id="reunion-modal" class="modal">
  <div class="modal-content">
    <div class="modal-title">Agendar reunión</div>
    <div class="form-group">
      <label>Tipo de reunión</label>
      <input type="text" id="reunion-title" placeholder="Ej: Reunión general">
    </div>
    <div class="form-group">
      <label>Fecha y hora</label>
      <input type="datetime-local" id="reunion-datetime">
    </div>
    <div class="form-group">
      <label>Descripción</label>
      <textarea id="reunion-desc" placeholder="Temas a tratar..."></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('reunion-modal')">Cancelar</button>
      <button class="btn btn-primary" onclick="saveReunion()">Guardar</button>
    </div>
  </div>
</div>

<div id="vocero-modal" class="modal">
  <div class="modal-content">
    <div class="modal-title">Agregar vocero</div>
    <div class="form-group">
      <label>Nombre</label>
      <input type="text" id="vocero-name">
    </div>
    <div class="form-group">
      <label>Curso</label>
      <input type="text" id="vocero-curso">
    </div>
    <div class="form-group">
      <label>Cargo</label>
      <select id="vocero-cargo">
        <option>Vocero</option>
        <option>Vocero coordinador</option>
        <option>Suplente</option>
      </select>
    </div>
    <div class="form-group">
      <label>Contacto</label>
      <input type="text" id="vocero-contacto" placeholder="Teléfono o email">
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('vocero-modal')">Cancelar</button>
      <button class="btn btn-primary" onclick="saveVocero()">Guardar</button>
    </div>
  </div>
</div>

<div id="tarea-modal" class="modal">
  <div class="modal-content">
    <div class="modal-title">Asignar tarea</div>
    <div class="form-group">
      <label>Nombre de la tarea</label>
      <input type="text" id="tarea-title">
    </div>
    <div class="form-group">
      <label>Asignar a</label>
      <input type="text" id="tarea-asignado">
    </div>
    <div class="form-group">
      <label>Fecha de entrega</label>
      <input type="date" id="tarea-fecha">
    </div>
    <div class="form-group">
      <label>Estado</label>
      <select id="tarea-estado">
        <option>Pendiente</option>
        <option>En progreso</option>
        <option>Completada</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('tarea-modal')">Cancelar</button>
      <button class="btn btn-primary" onclick="saveTarea()">Guardar</button>
    </div>
  </div>
</div>

<div id="propuesta-modal" class="modal">
  <div class="modal-content">
    <div class="modal-title">Enviar propuesta</div>
    <div class="form-group">
      <label>Tema</label>
      <select id="propuesta-tema">
        <option>Infraestructura</option>
        <option>Actividades</option>
        <option>Comunicación</option>
        <option>Otro</option>
      </select>
    </div>
    <div class="form-group">
      <label>Descripción de la propuesta</label>
      <textarea id="propuesta-desc" placeholder="Cuéntanos tu idea..."></textarea>
    </div>
    <div class="form-group">
      <label>Tu curso (opcional)</label>
      <input type="text" id="propuesta-curso">
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('propuesta-modal')">Cancelar</button>
      <button class="btn btn-primary" onclick="savePropuesta()">Enviar</button>
    </div>
  </div>
</div>

<div id="blog-modal" class="modal">
  <div class="modal-content">
    <div class="modal-title">Nueva noticia</div>
    <div class="form-group">
      <label>Titular</label>
      <input type="text" id="blog-title">
    </div>
    <div class="form-group">
      <label>Contenido</label>
      <textarea id="blog-body" placeholder="Escribe la noticia..."></textarea>
    </div>
    <div class="form-group">
      <label>Categoría</label>
      <select id="blog-category">
        <option>General</option>
        <option>Evento</option>
        <option>Anuncio</option>
        <option>Opinión</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-secondary" onclick="closeModal('blog-modal')">Cancelar</button>
      <button class="btn btn-primary" onclick="saveBlog()">Publicar</button>
    </div>
  </div>
</div>

<script>
  // STATE
  let currentUser = null;
  let currentRole = null;
  let data = {
    reuniones: [],
    voceros: [],
    tareas: [],
    propuestas: [],
    blog: [],
    avisos: [],
    comunicacion: []
  };
  
  // LOGIN
  document.getElementById('role-select').addEventListener('change', (e) => {
    const pinGroup = document.getElementById('pin-group');
    const nameGroup = document.getElementById('name-group');
    if(e.target.value === 'coordinator') {
      pinGroup.style.display = 'flex';
      nameGroup.style.display = 'none';
    } else if(e.target.value === 'vocero') {
      pinGroup.style.display = 'none';
      nameGroup.style.display = 'flex';
    }
  });
  
  function login() {
    const role = document.getElementById('role-select').value;
    if(role === 'coordinator') {
      const pin = document.getElementById('pin-input').value;
      if(pin !== '1234') {
        alert('PIN incorrecto');
        return;
      }
      currentUser = 'Coordinador';
      currentRole = 'coordinator';
    } else if(role === 'vocero') {
      const name = document.getElementById('name-input').value.trim();
      if(!name) {
        alert('Ingresa tu nombre');
        return;
      }
      currentUser = name;
      currentRole = 'vocero';
    } else {
      alert('Selecciona un rol');
      return;
    }
    
    document.getElementById('login-page').style.display = 'none';
    document.getElementById('app').style.display = 'flex';
    document.getElementById('user-name').textContent = currentUser;
    document.getElementById('user-role').textContent = currentRole === 'coordinator' ? 'COORDINADOR' : 'VOCERO';
    
    // Mostrar botones según rol
    if(currentRole === 'coordinator') {
      document.getElementById('new-aviso-btn').style.display = 'inline-block';
      document.getElementById('new-reunion-btn').style.display = 'inline-block';
      document.getElementById('new-vocero-btn').style.display = 'block';
      document.getElementById('new-tarea-btn').style.display = 'block';
      document.getElementById('new-evento-btn').style.display = 'block';
      document.getElementById('new-msg-btn').style.display = 'block';
      document.getElementById('blog-section').style.display = 'block';
    } else {
      document.getElementById('blog-section').style.display = 'block';
    }
    
    loadData();
    renderDashboard();
  }
  
  function logout() {
    currentUser = null;
    currentRole = null;
    document.getElementById('login-page').style.display = 'flex';
    document.getElementById('app').style.display = 'none';
    document.getElementById('role-select').value = '';
    document.getElementById('pin-input').value = '';
    document.getElementById('name-input').value = '';
  }
  
  // DATA PERSISTENCE
  async function loadData() {
    try {
      const result = await window.storage.get('voceros-data', true);
      if(result) data = JSON.parse(result.value);
    } catch(e) {
      console.error('Error loading:', e);
    }
  }
  
  async function saveData() {
    try {
      await window.storage.set('voceros-data', JSON.stringify(data), true);
    } catch(e) {
      console.error('Error saving:', e);
    }
  }
  
  // PANEL NAVIGATION
  function showPanel(panel) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel-' + panel).classList.add('active');
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    event.target.closest('.nav-btn').classList.add('active');
    
    if(panel === 'voceros') renderVoceros();
    if(panel === 'tareas') renderTareas();
    if(panel === 'agenda') renderAgenda();
    if(panel === 'propuestas') renderPropuestas();
    if(panel === 'comunicacion') renderComunicacion();
    if(panel === 'blog') renderBlog();
  }
  
  // MODALS
  function openModal(id) {
    document.getElementById(id).classList.add('active');
  }
  
  function closeModal(id) {
    document.getElementById(id).classList.remove('active');
  }
  
  function toggleReunionForm() {
    openModal('reunion-modal');
  }
  
  function toggleVoceroForm() {
    openModal('vocero-modal');
  }
  
  function toggleTareaForm() {
    openModal('tarea-modal');
  }
  
  function toggleEventoForm() {
    openModal('evento-modal');
  }
  
  function togglePropuestaForm() {
    openModal('propuesta-modal');
  }
  
  function toggleBlogForm() {
    openModal('blog-modal');
  }
  
  function toggleMsgForm() {
    prompt('Escribí el anuncio:', '') && saveMsg(prompt('Anuncio:'));
  }
  
  function toggleAvisoForm() {
    const titulo = prompt('Titulo del aviso:');
    if(titulo) {
      data.avisos.push({title: titulo, tipo: 'INFO', date: new Date().toISOString()});
      saveData();
      renderDashboard();
    }
  }
  
  // SAVE FUNCTIONS
  function saveReunion() {
    const title = document.getElementById('reunion-title').value;
    const datetime = document.getElementById('reunion-datetime').value;
    const desc = document.getElementById('reunion-desc').value;
    if(!title || !datetime) return alert('Completa los campos');
    
    data.reuniones.push({title, datetime, desc, estado: 'CONFIRMADA'});
    saveData();
    closeModal('reunion-modal');
    document.getElementById('reunion-title').value = '';
    document.getElementById('reunion-datetime').value = '';
    document.getElementById('reunion-desc').value = '';
    renderDashboard();
  }
  
  function saveVocero() {
    const name = document.getElementById('vocero-name').value;
    const curso = document.getElementById('vocero-curso').value;
    const cargo = document.getElementById('vocero-cargo').value;
    const contacto = document.getElementById('vocero-contacto').value;
    if(!name || !curso) return alert('Completa los campos');
    
    data.voceros.push({name, curso, cargo, contacto});
    saveData();
    closeModal('vocero-modal');
    document.getElementById('vocero-name').value = '';
    document.getElementById('vocero-curso').value = '';
    document.getElementById('vocero-contacto').value = '';
    renderVoceros();
  }
  
  function saveTarea() {
    const title = document.getElementById('tarea-title').value;
    const asignado = document.getElementById('tarea-asignado').value;
    const fecha = document.getElementById('tarea-fecha').value;
    const estado = document.getElementById('tarea-estado').value;
    if(!title) return alert('Completa los campos');
    
    data.tareas.push({title, asignado, fecha, estado});
    saveData();
    closeModal('tarea-modal');
    document.getElementById('tarea-title').value = '';
    document.getElementById('tarea-asignado').value = '';
    document.getElementById('tarea-fecha').value = '';
    renderTareas();
  }
  
  function savePropuesta() {
    const tema = document.getElementById('propuesta-tema').value;
    const desc = document.getElementById('propuesta-desc').value;
    const curso = document.getElementById('propuesta-curso').value;
    if(!desc) return alert('Escribe tu propuesta');
    
    data.propuestas.push({tema, desc, curso, estado: 'nueva', autor: currentUser, date: new Date().toISOString()});
    saveData();
    closeModal('propuesta-modal');
    document.getElementById('propuesta-desc').value = '';
    document.getElementById('propuesta-curso').value = '';
    alert('¡Propuesta enviada exitosamente!');
    renderPropuestas();
  }
  
  function saveBlog() {
    const title = document.getElementById('blog-title').value;
    const body = document.getElementById('blog-body').value;
    const category = document.getElementById('blog-category').value;
    if(!title || !body) return alert('Completa los campos');
    
    data.blog.unshift({title, body, category, autor: currentUser, date: new Date().toISOString()});
    saveData();
    closeModal('blog-modal');
    document.getElementById('blog-title').value = '';
    document.getElementById('blog-body').value = '';
    alert('¡Noticia publicada!');
    renderBlog();
  }
  
  // RENDER FUNCTIONS
  function renderDashboard() {
    document.getElementById('stat-reuniones').textContent = data.reuniones.length;
    document.getElementById('stat-tareas').textContent = data.tareas.filter(t => t.estado !== 'Completada').length;
    document.getElementById('stat-voceros').textContent = data.voceros.length;
    document.getElementById('stat-propuestas').textContent = data.propuestas.length;
    
    let html = '';
    data.reuniones.slice(0,3).forEach(r => {
      const fecha = new Date(r.datetime).toLocaleDateString('es-AR');
      html += `<div class="list-item"><div><div class="list-item-title">${r.title}</div><div class="list-item-meta">${fecha}</div></div><div class="badge badge-success">${r.estado}</div></div>`;
    });
    document.getElementById('reuniones-list').innerHTML = html || '<div class="list-item">Sin reuniones agendadas</div>';
  }
  
  function renderVoceros() {
    let html = '';
    const cursos = [...new Set(data.voceros.map(v => v.curso))];
    cursos.forEach(curso => {
      const vocerosCurso = data.voceros.filter(v => v.curso === curso);
      html += `<div style="padding:16px 20px;border-bottom:1px solid var(--border);"><strong>${curso}</strong></div>`;
      vocerosCurso.forEach(v => {
        html += `<div class="list-item" style="padding-left:40px;"><div><div class="list-item-title">${v.name}</div><div class="list-item-meta">${v.cargo} • ${v.contacto || 'Sin contacto'}</div></div></div>`;
      });
    });
    document.getElementById('voceros-content').innerHTML = html || '<p style="color:var(--text-muted);text-align:center;padding:20px;">No hay voceros aún</p>';
  }
  
  function renderTareas() {
    let html = '';
    data.tareas.forEach(t => {
      const colorEstado = t.estado === 'Completada' ? 'badge-success' : t.estado === 'En progreso' ? 'badge-warning' : 'badge-blue';
      html += `<div class="list-item"><div><div class="list-item-title">${t.title}</div><div class="list-item-meta">Asignado a: ${t.asignado} • ${t.fecha}</div></div><div class="badge ${colorEstado}">${t.estado}</div></div>`;
    });
    document.getElementById('tareas-content').innerHTML = html || '<p style="color:var(--text-muted);text-align:center;padding:20px;">Sin tareas</p>';
  }
  
  function renderAgenda() {
    let html = '';
    data.reuniones.forEach(r => {
      html += `<div class="list-item"><div><div class="list-item-title">${r.title}</div><div class="list-item-meta">${new Date(r.datetime).toLocaleDateString('es-AR')} • ${r.desc}</div></div></div>`;
    });
    document.getElementById('agenda-content').innerHTML = html || '<p style="color:var(--text-muted);text-align:center;padding:20px;">Sin eventos</p>';
  }
  
  function renderPropuestas() {
    let html = '';
    data.propuestas.forEach(p => {
      const colorEstado = p.estado === 'ejecutada' ? 'badge-success' : p.estado === 'en revisión' ? 'badge-warning' : 'badge-blue';
      html += `<div class="list-item"><div style="flex:1;"><div class="list-item-title">${p.tema}</div><div class="list-item-meta">${p.desc.substring(0,60)}... • ${p.autor}</div></div><div class="badge ${colorEstado}">${p.estado}</div></div>`;
    });
    document.getElementById('propuestas-content').innerHTML = html || '<p style="color:var(--text-muted);text-align:center;padding:20px;">No hay propuestas</p>';
  }
  
  function renderComunicacion() {
    let html = '';
    data.comunicacion.forEach(m => {
      html += `<div class="list-item"><div><div class="list-item-title">${m.title}</div><div class="list-item-meta">${m.author}</div></div></div>`;
    });
    document.getElementById('comunicacion-content').innerHTML = html || '<p style="color:var(--text-muted);text-align:center;padding:20px;">Sin anuncios</p>';
  }
  
  function renderBlog() {
    let html = '';
    data.blog.forEach(post => {
      const fecha = new Date(post.date).toLocaleDateString('es-AR');
      html += `<div style="background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:20px;margin-bottom:16px;"><div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;"><h3 style="margin:0;font-size:18px;font-weight:600;">${post.title}</h3><span class="badge badge-blue">${post.category}</span></div><p style="margin:8px 0;color:var(--text-secondary);line-height:1.6;white-space:pre-wrap;">${post.body}</p><div style="font-size:12px;color:var(--text-muted);margin-top:12px;">Por ${post.autor} • ${fecha}</div></div>`;
    });
    document.getElementById('blog-content').innerHTML = html || '<p style="color:var(--text-muted);text-align:center;padding:40px;">No hay noticias aún. ¡Sé el primero en publicar!</p>';
  }
  
  // INIT
  loadData();
</script>

</body>
</html>
